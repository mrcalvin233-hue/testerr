<%- include('partials/header') %>
<div class="auth-container card">
  <h2 style="text-align:center; margin-bottom: 1rem; color: var(--primary);">Lupa Password?</h2>
  <p style="text-align:center; color: var(--text-muted); margin-bottom: 2rem; font-size: 0.9rem;">
    Masukkan email Anda dan kami akan mengirimkan tautan untuk mengatur ulang kata sandi Anda.
  </p>
  
  <% if (error) { %>
    <div class="alert badge-expense" style="margin-bottom: 1.5rem; justify-content: center;"><%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert badge-income" style="margin-bottom: 1.5rem; justify-content: center;"><%= success %></div>
  <% } %>

  <form action="/forgot-password" method="POST">
    <div class="form-group">
      <label>Alamat Email</label>
      <input type="email" name="email" class="form-control" required placeholder="email@contoh.com">
    </div>
    <button type="submit" class="btn btn-primary btn-block">Kirim Tautan Reset</button>
  </form>

  <p style="text-align:center; margin-top: 1.5rem; color: var(--text-muted);">
    Ingat password Anda? <a href="/login" style="color:var(--primary); font-weight:500;">Kembali ke Login</a>
  </p>
</div>
<%- include('partials/footer') %>
