<%- include('partials/header') %>

<div class="grid" style="margin-bottom: 2rem;">
  <div class="stat-card balance">
    <h3>Total Pengguna</h3>
    <h2><%= profiles.length %></h2>
  </div>
  <div class="stat-card income">
    <h3>Total Pemasukan Sistem</h3>
    <h2>Rp <%= totalIncome.toLocaleString('id-ID') %></h2>
  </div>
  <div class="stat-card expense">
    <h3>Total Pengeluaran Sistem</h3>
    <h2>Rp <%= totalExpense.toLocaleString('id-ID') %></h2>
  </div>
</div>

<div class="grid" style="grid-template-columns: 2fr 1fr; margin-bottom: 2rem;">
  <!-- User Growth Chart -->
  <div class="card">
    <h3 style="margin-bottom: 1.5rem; color: var(--text-main); font-weight: 600;"><i class="fas fa-users" style="color:var(--primary); margin-right: 0.5rem;"></i> Pertumbuhan Pengguna</h3>
    <div style="position: relative; height: 300px; width: 100%;">
      <canvas id="userGrowthChart"></canvas>
    </div>
  </div>

  <!-- Top Users Card -->
  <div class="card">
    <h3 style="margin-bottom: 1.5rem; color: var(--text-main); font-weight: 600;"><i class="fas fa-trophy" style="color:#fbbf24; margin-right: 0.5rem;"></i> Pengguna Paling Aktif</h3>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <% topUsersData.forEach((u, i) => { %>
        <div style="display:flex; justify-content: space-between; align-items: center; padding: 0.75rem; background: rgba(255,255,255,0.03); border-radius: 8px;">
          <div style="display:flex; align-items: center; gap: 0.75rem;">
            <span style="width: 24px; height: 24px; background: <%= i === 0 ? '#fbbf24' : 'var(--glass-border)' %>; border-radius: 50%; display: flex; align-items:center; justify-content:center; font-size: 0.75rem; font-weight: bold; color: <%= i === 0 ? '#000' : 'var(--text-muted)' %>"><%= i + 1 %></span>
            <span style="font-weight: 500;"><%= u.name %></span>
          </div>
          <span style="color: var(--primary); font-size: 0.85rem; font-weight: 600;"><%= u.count %> Transaksi</span>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<div class="card">
  <h3 style="margin-bottom: 1.5rem;">Manajemen Pengguna</h3>
  <div class="table-responsive">
    <table>
      <thead>
        <tr>
          <th>Nama</th>
          <th>Role</th>
          <th>Status</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% profiles.forEach(p => { %>
          <tr>
            <td><strong><%= p.name %></strong> <br> <small style="color:var(--text-muted);"><%= p.id %></small></td>
            <td><%= p.role.toUpperCase() %></td>
            <td>
              <span class="badge <%= p.status === 'active' ? 'badge-income' : 'badge-expense' %>">
                <%= p.status %>
              </span>
            </td>
            <td>
              <button type="button" class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;" 
                onclick="KeuanganKu.confirm('Reset Password', 'Password akan di-reset ke: password123. Lanjut?').then(ok => { if(ok) document.getElementById('resetForm-<%= p.id %>').submit(); })">Reset Pwd</button>
              <form id="resetForm-<%= p.id %>" action="/admin/user/<%= p.id %>/password" method="POST" style="display:none;">
                <input type="hidden" name="newPassword" value="password123">
              </form>
              
              <form action="/admin/user/<%= p.id %>/status" method="POST" style="display:inline-block; margin-right: 0.5rem;">
                <input type="hidden" name="status" value="<%= p.status === 'active' ? 'inactive' : 'active' %>">
                <button type="submit" class="btn btn-primary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">
                  <%= p.status === 'active' ? 'Nonaktifkan' : 'Aktifkan' %>
                </button>
              </form>
              
              <button type="button" class="btn btn-danger" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;"
                onclick="KeuanganKu.confirm('Hapus Pengguna', 'Hapus pengguna <%= p.name %> secara permanen? Data tidak bisa dikembalikan.').then(ok => { if(ok) document.getElementById('deleteForm-<%= p.id %>').submit(); })">Hapus</button>
              <form id="deleteForm-<%= p.id %>" action="/admin/user/<%= p.id %>/delete" method="POST" style="display:none;"></form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const growthLabels = <%- JSON.stringify(growthLabels || []) %>;
  const growthValues = <%- JSON.stringify(growthValues || []) %>;

  if (growthLabels.length > 0) {
    const ctxGrowth = document.getElementById('userGrowthChart').getContext('2d');
    const gradient = ctxGrowth.createLinearGradient(0, 0, 0, 300);
    gradient.addColorStop(0, 'rgba(129, 140, 248, 0.5)');
    gradient.addColorStop(1, 'rgba(129, 140, 248, 0)');

    new Chart(ctxGrowth, {
      type: 'line',
      data: {
        labels: growthLabels,
        datasets: [{
          label: 'Registrasi Baru',
          data: growthValues,
          borderColor: '#818cf8',
          backgroundColor: gradient,
          fill: true,
          tension: 0.4,
          pointBackgroundColor: '#818cf8',
          borderWidth: 3
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: { color: 'rgba(255, 255, 255, 0.05)' },
            ticks: { color: '#94a3b8', stepSize: 1 }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#94a3b8' }
          }
        }
      }
    });
  }
</script>

<%- include('partials/footer') %>
