<%- include('partials/header') %>

<div class="card" style="max-width: 600px; margin: 0 auto;">
  <h2 style="margin-bottom: 1.5rem; text-align: center; color: var(--primary);">Atur Profil</h2>

  <% if (error) { %>
    <div class="alert" style="background: rgba(251,113,133,0.15); border: 1px solid var(--danger); color: var(--danger);"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert" style="background: rgba(52,211,153,0.15); border: 1px solid var(--success); color: var(--success);"><%= success %></div>
  <% } %>

  <div style="margin-bottom: 2.5rem;">
    <h3 style="margin-bottom: 1rem; color: var(--text-main);">Ubah Nama</h3>
    <form action="/profile/name" method="POST">
      <div class="form-group">
        <label>Nama Lengkap</label>
        <input type="text" name="name" class="form-control" value="<%= user.name %>" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-user-edit"></i> Simpan Nama</button>
    </form>
  </div>

  <hr style="border: 0; border-top: 1px solid var(--glass-border); margin-bottom: 2.5rem;">

  <div style="margin-bottom: 2.5rem;">
    <h3 style="margin-bottom: 1rem; color: var(--text-main);">Target Anggaran Bulanan</h3>
    <form action="/profile/budget" method="POST">
      <div class="form-group">
        <label>Batas Maksimal Pengeluaran (Rp)</label>
        <input type="number" name="monthly_budget" class="form-control" value="<%= user.monthly_budget || 0 %>" min="0" required>
        <small style="color:var(--text-muted); display:block; margin-top:0.5rem;">Set ke 0 untuk menonaktifkan fitur Anggaran.</small>
      </div>
      <button type="submit" class="btn btn-secondary btn-block"><i class="fas fa-bullseye"></i> Simpan Anggaran</button>
    </form>
  </div>

  <hr style="border: 0; border-top: 1px solid var(--glass-border); margin-bottom: 2.5rem;">

  <div>
    <h3 style="margin-bottom: 1rem; color: var(--text-main);">Ubah Password</h3>
    <form action="/profile/password" method="POST">
      <div class="form-group">
        <label>Password Baru</label>
        <input type="password" name="password" class="form-control" required placeholder="Minimal 6 karakter">
      </div>
      <div class="form-group">
        <label>Konfirmasi Password</label>
        <input type="password" name="confirmPassword" class="form-control" required placeholder="Ketik ulang password baru">
      </div>
      <button type="submit" class="btn btn-danger btn-block"><i class="fas fa-key"></i> Update Password</button>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
