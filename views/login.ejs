<%- include('partials/header') %>
<div class="auth-container card">
  <h2 style="text-align:center; margin-bottom: 2rem; color: var(--primary);">Login ke Akun Anda</h2>
  
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <script>
    if (window.location.search.includes('registered=1')) {
      KeuanganKu.alert('🎉 Berhasil!', 'Akun Anda berhasil dibuat. Silakan login untuk memulai.');
      history.replaceState(null, '', '/login');
    }
  </script>

  <form action="/login" method="POST">
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" class="form-control" required placeholder="email@contoh.com">
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" class="form-control" required placeholder="••••••••">
    </div>
    <button type="submit" class="btn btn-primary btn-block">Masuk</button>
    <div style="text-align: right; margin-top: 0.5rem;">
      <a href="/forgot-password" style="color:var(--text-muted); font-size: 0.85rem; text-decoration: none;">Lupa password?</a>
    </div>
  </form>

  <p style="text-align:center; margin-top: 1.5rem; color: var(--text-muted);">
    Belum punya akun? <a href="/register" style="color:var(--primary); font-weight:500;">Daftar di sini</a>
  </p>
</div>
<%- include('partials/footer') %>
