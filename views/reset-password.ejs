<%- include('partials/header') %>
<div class="auth-container card">
  <h2 style="text-align:center; margin-bottom: 1rem; color: var(--primary);">Atur Ulang Password</h2>
  <p style="text-align:center; color: var(--text-muted); margin-bottom: 2rem; font-size: 0.9rem;">
    Silakan masukkan kata sandi baru Anda di bawah ini.
  </p>
  
  <div id="msgContainer"></div>

  <form id="resetForm">
    <div class="form-group">
      <label>Password Baru</label>
      <input type="password" id="newPassword" class="form-control" required placeholder="••••••••" minlength="6">
    </div>
    <div class="form-group">
      <label>Konfirmasi Password Baru</label>
      <input type="password" id="confirmPassword" class="form-control" required placeholder="••••••••" minlength="6">
    </div>
    <button type="submit" class="btn btn-primary btn-block" id="submitBtn">Simpan Password Baru</button>
  </form>

  <p style="text-align:center; margin-top: 1.5rem; color: var(--text-muted);">
    <a href="/login" style="color:var(--primary); font-weight:500;">Kembali ke Login</a>
  </p>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
  // Initialize Supabase client for client-side update
  // We need to fetch the config from the server or use defaults if common
  // But wait, it's better to just use the access token in the hash if it exists
  const resetForm = document.getElementById('resetForm');
  const msgContainer = document.getElementById('msgContainer');
  const submitBtn = document.getElementById('submitBtn');

  resetForm.onsubmit = async (e) => {
    e.preventDefault();
    const password = document.getElementById('newPassword').value;
    const confirm = document.getElementById('confirmPassword').value;

    if (password !== confirm) {
      msgContainer.innerHTML = '<div class="alert badge-expense" style="margin-bottom: 1.5rem; justify-content: center;">Password tidak cocok!</div>';
      return;
    }

    submitBtn.innerText = 'Memproses...';
    submitBtn.disabled = true;

    try {
      // Send to server to update password
      // The server will use the access token from the session created by Supabase callback
      const response = await fetch('/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password })
      });

      const result = await response.json();
      if (result.success) {
        msgContainer.innerHTML = '<div class="alert badge-income" style="margin-bottom: 1.5rem; justify-content: center;">Selamat! Password berhasil diubah. Mengalihkan ke login...</div>';
        setTimeout(() => window.location.href = '/login', 2000);
      } else {
        throw new Error(result.error || 'Gagal mengubah password');
      }
    } catch (err) {
      msgContainer.innerHTML = `<div class="alert badge-expense" style="margin-bottom: 1.5rem; justify-content: center;">${err.message}</div>`;
      submitBtn.innerText = 'Simpan Password Baru';
      submitBtn.disabled = false;
    }
  };
</script>
<%- include('partials/footer') %>
